# Generated into .runtime.env by scripts/start-preview.sh.
# Never commit the generated file.
AI_EDITOR_PREVIEW_PUBLIC_ORIGIN=
AI_EDITOR_PROVIDER_WORKER_SIGNING_SECRET=
AI_EDITOR_PREVIEW_EXECUTOR=mock
AI_EDITOR_WORKER_HTTPS_PROXY=
AI_EDITOR_PREVIEW_UID=1000
AI_EDITOR_PREVIEW_GID=1000

# Preview images are intentionally configurable. Pin immutable digests before
# using the same shape for a production release.
AI_EDITOR_CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest
AI_EDITOR_MIHOMO_IMAGE=metacubex/mihomo:stable
