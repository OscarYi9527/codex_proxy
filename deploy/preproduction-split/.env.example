# Generated as .worker.runtime.env on the Singapore host and
# .gateway.runtime.env on the China Gateway host. Never commit either file.
AI_EDITOR_PROVIDER_WORKER_SIGNING_SECRET=
AI_EDITOR_PREPRODUCTION_UID=1000
AI_EDITOR_PREPRODUCTION_GID=1000
CODEX_PROXY_MAX_BODY_MIB=64
CODEX_PROXY_BODY_TIMEOUT_MS=60000
AI_EDITOR_DEBIAN_MIRROR=deb.debian.org

# Gateway host only.
AI_EDITOR_PREPRODUCTION_PUBLIC_ORIGIN=https://pending.invalid
AI_EDITOR_PREPRODUCTION_WORKER_ORIGIN=https://43.156.27.252:47930
AI_EDITOR_CHATGPT_LOGIN_HTTPS_PROXY=
AI_EDITOR_CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest
AI_EDITOR_CLOUDFLARED_PROTOCOL=http2

# Stable mainland direct ingress. Keep these unset while using Quick Tunnel.
# DNS must resolve the hostname to the domestic Gateway public IPv4 before the
# direct cutover script makes any runtime change.
AI_EDITOR_DIRECT_PUBLIC_ORIGIN=https://gateway.torvye.com
AI_EDITOR_DIRECT_EXPECTED_IPV4=114.132.161.56
AI_EDITOR_CADDY_IMAGE=mirror.ccs.tencentyun.com/library/caddy:2.10.2-alpine
