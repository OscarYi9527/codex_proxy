{
  "name": "@ai-editor/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "provider-credentials": "tsx src/provider-credentials-cli.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --experimental-vm-modules ../node_modules/jest/bin/jest.js --config jest.config.cjs --runInBand",
    "test:coverage": "node --experimental-vm-modules ../node_modules/jest/bin/jest.js --config jest.config.cjs --runInBand --coverage"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "13.1.0",
    "@node-rs/argon2": "^2.0.2",
    "better-sqlite3": "12.4.1",
    "fastify": "5.10.0",
    "jose": "^6.2.3",
    "kysely": "0.28.17",
    "pg": "8.16.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/jest": "29.5.14",
    "@types/node": "24.10.1",
    "@types/pg": "8.15.6",
    "jest": "29.7.0",
    "pg-mem": "3.0.5",
    "ts-jest": "29.4.5",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  }
}
