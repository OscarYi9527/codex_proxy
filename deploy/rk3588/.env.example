# Copy to deploy/rk3588/.env on the RK3588 host.
# Do not put API keys in this file; credentials are mounted from /etc/codex-rk3588.

RK3588_RELAY_PORT=47930
RK3588_ALLOWED_HOSTS=rk3588-relay.example-tailnet.ts.net
RK3588_UPSTREAM_ORIGIN=https://jp-relay.example.com
RK3588_MAX_IN_FLIGHT=8
RK3588_BODY_LIMIT_MB=16
RK3588_UPSTREAM_TIMEOUT_MS=600000
