{
  "name": "codex-proxy",
  "version": "2.4.1",
  "type": "module",
  "description": "Multi-upstream model routing proxy for Codex — ChatGPT subscription, OpenAI API, and DeepSeek",
  "main": "index.js",
  "bin": {
    "codex-proxy": "src/launcher.js"
  },
  "workspaces": [
    "gateway",
    "gateway/admin-web"
  ],
  "scripts": {
    "start": "node src/launcher.js",
    "start:standalone": "node src/launcher.js --mode standalone",
    "start:edge": "node src/launcher.js --mode edge",
    "gateway:dev": "npm run dev --workspace @ai-editor/gateway",
    "gateway:provider-credentials": "npm run provider-credentials --workspace @ai-editor/gateway --",
    "gateway:secret-scan": "npm run secret-scan --workspace @ai-editor/gateway",
    "gateway:build": "npm run build --workspace @ai-editor/gateway",
    "gateway:test": "npm run test --workspace @ai-editor/gateway",
    "admin:dev": "npm run dev --workspace @ai-editor/admin-web",
    "admin:build": "npm run build --workspace @ai-editor/admin-web",
    "admin:test": "npm run test --workspace @ai-editor/admin-web",
    "check": "node --check src/server.js && node --check src/launcher.js && node --check src/mode.js && node --check src/edge/edge-config.js && node --check src/edge/edge-server.js && node --check src/edge/gateway-client.js && node --check src/edge/local-account-store.js && node --check src/edge/local-handoff.js && node --check index.js && npm run check --workspace @ai-editor/gateway && npm run check --workspace @ai-editor/admin-web",
    "test": "node --test tests/*.js tests/*.cjs",
    "test:gateway-stack": "npm run gateway:test && npm run admin:test",
    "test:dev-scripts": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File tests/test-dev-scripts.ps1",
    "secret:scan": "node scripts/secret-scan.mjs",
    "release:check": "node scripts/release-check.mjs"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "keywords": [
    "codex",
    "proxy",
    "openai",
    "chatgpt",
    "deepseek",
    "model-router"
  ],
  "license": "MIT",
  "dependencies": {
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "5.1.1",
    "vite": "7.3.6"
  }
}
